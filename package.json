{
  "name": "@lore-hex/trusted-router",
  "version": "0.2.0",
  "description": "JavaScript SDK for TrustedRouter — typed errors, retries, region pinning, attestation verification.",
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./attestation": {
      "types": "./src/attestation.d.ts",
      "import": "./src/attestation.js"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "license": "Apache-2.0",
  "author": "Lore Hex",
  "homepage": "https://trustedrouter.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lore-Hex/trusted-router-js.git"
  },
  "bugs": {
    "url": "https://github.com/Lore-Hex/trusted-router-js/issues"
  },
  "scripts": {
    "check": "node --check src/index.js && node --check src/attestation.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "trustedrouter",
    "openai",
    "anthropic",
    "llm",
    "router",
    "attested",
    "confidential-computing"
  ]
}
