{
  "name": "@lore-hex/openclaw-trustedrouter-provider",
  "displayName": "TrustedRouter.com Provider",
  "version": "1.0.0",
  "description": "OpenClaw provider plugin for TrustedRouter.com, an end-to-end encrypted OpenRouter-compatible LLM router.",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "license": "Apache-2.0",
  "author": "Lore Hex",
  "homepage": "https://trustedrouter.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lore-Hex/trusted-router-js.git",
    "directory": "packages/openclaw-provider"
  },
  "bugs": {
    "url": "https://github.com/Lore-Hex/trusted-router-js/issues"
  },
  "scripts": {
    "check": "node --check index.js && node -e \"JSON.parse(require('node:fs').readFileSync('openclaw.plugin.json', 'utf8'))\"",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "openclaw",
    "clawhub",
    "trustedrouter",
    "trusted-router",
    "openrouter",
    "llm",
    "provider",
    "e2ee"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "providers": [
      "trustedrouter"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.5.17",
      "pluginSdkVersion": "2026.5.17"
    },
    "environment": {
      "env": [
        "TRUSTEDROUTER_API_KEY"
      ]
    }
  }
}
